#OFFICIAL FILE.
from sage.graphs.independent_sets import IndependentSets

def apply(L,fn):
    return [fn(elt) for elt in L]

def SizeOfComplex(K):
    return sum(len(K.faces()[n]) for n in range(0,dim(K)+1))

def evenLaplacian(K,d): #2nd var is dimension, this is EVEN Lap bet. d and d-1, linear map on C_(d-1) to itself
    co_K = K.chain_complex()
    return co_K.differential(d)*co_K.differential(d).transpose()

def oddLaplacian(K,d): #2nd var is dimension, this is ODD Lap bet. d and d-1, linear map on C_(d) to itself
    co_K = K.chain_complex()
    return co_K.differential(d).transpose()*co_K.differential(d)

def Laplacian(K,d):
    return evenLaplacian(K,d+1) + oddLaplacian(K,d)

def _orient_matching(matching):
    return [path[::-1] if len(path[0]) < len(path[1]) else path for path in matching]

def _filter_acyclic(all_matchings, hasse_graph):
    HG = DiGraph(hasse_graph.edges(labels=False))
    res = []
    for matching in all_matchings:
        clean_matching = _orient_matching(matching)
        HG.reverse_edges(clean_matching)
        if HG.is_directed_acyclic():
            res.append(clean_matching)
        # Undo the reversal instead of rebuilding the entire DiGraph
        HG.reverse_edges([(e[1],e[0]) for e in clean_matching])
    return res

def acyclicmatchings(K): #takes input complex K and returns list of acyclic matchings, esentially all possible gradients on K
    hasse_graph = DiGraph(K.face_poset().hasse_diagram().to_directed().reverse().edges(labels=False))
    all_matchings = list(IndependentSets(hasse_graph.to_undirected().line_graph(labels=False))) #needs each element ordered higher to lower dim
    return _filter_acyclic(all_matchings, hasse_graph)

def limited_acyclicmatchings(K,L):
    P = K.face_poset()
    faces = K.faces()
    ignored_levels = set(n for n in range(len(L)) if L[n] == len(faces[n])) #if num crit cells is num faces, face to be deleted
    kept_elements = [elt for elt in list(P) if P.rank(elt) not in ignored_levels]
    hasse_graph = DiGraph(P.subposet(kept_elements).hasse_diagram().to_directed().reverse().edges(labels=False))
    all_matchings = list(IndependentSets(hasse_graph.to_undirected().line_graph(labels=False))) #needs each element ordered higher to lower dim
    return _filter_acyclic(all_matchings, hasse_graph)

#takes input complex K and list L = [n_0, n_1, n_2, ..., n_dimK]
#where the critical vector is [K_0 - n_1, K_1 - n_2, ..., K_dim(K) - n_dim(K)]
def gradients(K,L):
    faces = K.faces()
    reversal = [len(faces[k]) - L[k] for k in range(len(L))]
    L = reversal
    KE = K.euler_characteristic()
    safety = sum((-1)^k*L[k] for k in range(len(L)))
    if KE != safety:
        print("Error: List does not satisfy Weak Morse Inequality. Euler characteristic is " + str(KE) + ".")
        return
    res = []
    d = dim(K)
    pool = limited_acyclicmatchings(K,L)
    face_counts = [len(faces[n]) for n in range(d+1)]
    for matching in pool:
        # Single-pass dimension counting instead of scanning matching per dimension
        dim_counts = [0] * (d+1)
        for pair in matching:
            for cell in pair:
                level = len(cell) - 1
                if 0 <= level <= d:
                    dim_counts[level] += 1
        ok = True
        for n in range(0,d+1):
            if L[n] != face_counts[n] - dim_counts[n]: #checks correct num crit cells
                ok = False
                break
        if ok:
            res.append(matching)
    return res

def hasse_levels(K,L): #L is the list of levels desired (ideally adjacent)
    P = K.face_poset()
    L_set = set(L)
    return P.subposet([x for x in list(P) if P.rank(x) in L_set])


