#CONJECTURE CHECKING ITEMS BELOW
##########

def morse_set_vectors(K,d):
    faces = K.faces()
    L = [len(faces[n]) for n in range(dim(K)+1)]
    LOW = min(L[d],L[d-1])
    res = []
    for n in range(LOW+1):
        vec = [L[j] - n if (j == d or j == d-1) else L[j] for j in range(len(L))]
        res.append(vec)
    return res

def limited_acyclicmatchings2(K,d):
    P = K.face_poset()
    kept_levels = {d, d-1}
    kept_elements = [elt for elt in list(P) if P.rank(elt) in kept_levels]
    hasse_graph = DiGraph(P.subposet(kept_elements).hasse_diagram().to_directed().reverse().edges(labels=False))
    all_matchings = list(IndependentSets(hasse_graph.to_undirected().line_graph(labels=False))) #needs each element ordered higher to lower dim
    return _filter_acyclic(all_matchings, hasse_graph)

def strainer(K,d,pool,vec):
    res = []
    d = dim(K)
    face_counts = [len(K.faces()[n]) for n in range(d+1)]
    for matching in pool:
        # Single-pass dimension counting instead of scanning matching per dimension
        dim_counts = [0] * (d+1)
        for pair in matching:
            for cell in pair:
                level = len(cell) - 1
                if 0 <= level <= d:
                    dim_counts[level] += 1
        ok = True
        for n in range(0,d+1):
            if vec[n] != face_counts[n] - dim_counts[n]: #checks correct num crit cells
                ok = False
                break
        if ok:
            res.append(matching)
    return res

def grad_list(K,d):
    vec_list = morse_set_vectors(K,d)
    #pool = limited_acyclicmatchings(K)
    grads = []
    pool = limited_acyclicmatchings2(K,d)
    for vec in vec_list:
        res = strainer(K,d,pool,vec)
        grads.append(len(res))
    return grads

def evenLap_coeff(K,d):
    poly = evenLaplacian(K,d).charpoly().coefficients(sparse=False)
    poly.reverse()
    return apply(poly,abs)

def checker(K,d):
    L1 = evenLap_coeff(K,d)
    L2 = grad_list(K,d)
    for n in range(min(len(L1),len(L2))):
        if L1[n] != L2[n]:
            #print(str(L1))
            #print(str(L2))
            return False
    #print(str(L1))
    #print(str(L2))
    return True

def conj_checker(K):
    fails = []
    status = True
    for d in [1 .. dim(K)]:
        if not checker(K,d):
            status = False
            fails.append(d)
            #print("Failure for dimension d = " + str(d) + ":")
            #print("")
    return [status,fails]

def poset_iterator(n): #iterates over order complexes of all possible posets on n-many elements
    resevoir = posets(n)
    print("Will check " + str(len(resevoir)) + " posets.")
    for k in range(len(resevoir)):
        K = resevoir[k].order_complex()
        res = conj_checker(K)
        if not res[0]:
            print("Failure on poset " + str(k) + ". Dimension: " + str(dim(K)) + ". Errors in following dimensions:" + str(res[1]))
        else:
            print("Success for poset " + str(k) + ".")
        #print("~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~")
        #print("Checking poset " + str(k) + " in list.")
        #print("~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~")
        #K = resevoir[k].order_complex()
        #conj_checker(K)
    return

#for returning list (of lists) of all cells of K, for input into topaz
def topaz(K):
    res = []
    for n in range(dim(K)+1):
        res = res + apply(list(K.faces()[n]),list)
    print("$s = new SimplicialComplex(INPUT_FACES=>" + str(res) + ");")
    print("$s->VISUAL;")
    return


